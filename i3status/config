general {
  colors = false
  interval = 1
}
order += "brightness"
order += "cpu_usage"
order += "ethernet enp1s0"
order += "wireless _first_"
order += "cpu_temperature 0"
order += "load"
order += "memory"
order += "volume master"
order += "battery all"
order += "tztime local"


wireless _first_ {
  format_up = "NET %quality - %essid"
  format_down = "NET DOWN"
}

ethernet enp1s0 {
   format_up = "ETH UP"
   format_down = "ETH DN"
}

cpu_usage {
  format = "CPU %usage"
}

cpu_temperature 0 {
  format = "TMP %degrees°C"
  path = "/sys/class/hwmon/hwmon4/temp1_input"
}

load {
  format = "LOD %5min"
}

memory {
  format = "RAM %used"
}

battery all {
  format = "BAT %status %percentage"
  format_down = "D"
  status_chr = "C"
  status_bat = "B"
  status_unk = "U"
  status_full = "F"
  status_idle = "I"
}

volume master {
  format = "VOL %volume"
  format_muted = "M"
  device = "default"
  mixer = "Master"
  mixer_idx = 0
}

tztime local {
  format = "%^a %d %^b %I:%M:%S  "
}
